# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
ALLOWED_ORIGIN=https://www.blaene.com.tr,https://blaene.com.tr,http://localhost:3000

# PayTR
PAYTR_MERCHANT_ID=YOUR_MERCHANT_ID
PAYTR_MERCHANT_KEY=YOUR_MERCHANT_KEY
PAYTR_MERCHANT_SALT=YOUR_MERCHANT_SALT
PAYTR_TEST_MODE=1
PAYTR_DEBUG_ON=0
PAYTR_NO_INSTALLMENT=0
PAYTR_MAX_INSTALLMENT=0
PAYTR_TIMEOUT_LIMIT=30

# Iyzico
IYZICO_API_KEY=YOUR_IYZICO_API_KEY
IYZICO_SECRET_KEY=YOUR_IYZICO_SECRET_KEY
# Optional. Defaults to sandbox endpoint.
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# Optional callback override. If empty, uses SITE_URL + /api/public/iyzico-callback
IYZICO_CALLBACK_URL=
# Optional browser return URLs after callback processing.
# Fallback order: IYZICO_*_URL -> PAYTR_*_URL -> SITE_URL/checkout.html?pay=ok|fail
IYZICO_SUCCESS_URL=
IYZICO_FAIL_URL=

# Checkout mode: auto | mock | paytr | iyzico
# auto: ayarlara gore once iyzico, sonra paytr, yoksa mock kullanir
CHECKOUT_MODE=auto
# Legacy override (true/false). true ise direkt mock moda gecer
MOCK_CHECKOUT_MODE=false
# true: checkout icin uye girisi zorunlu olur
CHECKOUT_REQUIRE_AUTH=false

# Public URLs
SITE_URL=https://your-domain.com
PAYTR_OK_URL=https://your-domain.com/checkout.html?pay=ok
PAYTR_FAIL_URL=https://your-domain.com/checkout.html?pay=fail

# Optional Redis rate-limit (fallback: in-memory)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend (e-posta gönderimi)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=Blaene <noreply@blaene.com.tr>
ADMIN_EMAIL=admin@blaene.com.tr
# Supabase auth webhook için (Supabase Dashboard > Webhooks > Secret)
SUPABASE_WEBHOOK_SECRET=your_webhook_secret

# Optional AI modules
ANTHROPIC_API_KEY=

# Marketplace credential encryption (AES-256-GCM). Required for encrypted credential storage.
CREDENTIALS_ENCRYPTION_KEY=

# Optional shipping adapters
SHIPPING_YURTICI_API_KEY=
SHIPPING_YURTICI_API_SECRET=
SHIPPING_MNG_API_KEY=
SHIPPING_MNG_API_SECRET=
SHIPPING_ARAS_API_KEY=
SHIPPING_ARAS_API_SECRET=
