{
  "rewrites": [
    {
      "source": "/admin/((?!api|login\\.html).*)",
      "destination": "/admin/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/auth",
      "destination": "/auth.html",
      "permanent": false
    },
    {
      "source": "/auth/",
      "destination": "/auth.html",
      "permanent": false
    },
    {
      "source": "/account",
      "destination": "/account.html",
      "permanent": false
    },
    {
      "source": "/account/",
      "destination": "/account.html",
      "permanent": false
    },
    {
      "source": "/checkout",
      "destination": "/checkout.html",
      "permanent": false
    },
    {
      "source": "/checkout/",
      "destination": "/checkout.html",
      "permanent": false
    }
  ]
}
